{
  "name": "pbs",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/inselbuehne",
    "apps/links",
    "apps/portal/extensions/editorjs",
    "apps/website",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "eslint-config-custom": "^0.0.0",
    "prettier": "^3.0.0",
    "turbo": "^1.13.4"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "packageManager": "pnpm@10.18.3"
}
