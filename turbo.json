{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".medusa/**"]
    },
    "lint": {
      "outputs": []
    },
    "website#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["MOLLIE_API_KEY", "WIX_API_KEY", "NEXT_PUBLIC_INSTAGRAM_TOKEN"]
    },
    "dev": {
      "cache": false
    }
  }
}
